<Window
    x:Class="理髮師問題WPF專案.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Sleeping Barber Simulator"
    Width="900"
    Height="600">

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Margin="0,0,-2.5,0"
            Panel.ZIndex="1"
            BorderBrush="Black"
            BorderThickness="0,0,5,0" />

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="1.5*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                BorderBrush="Black"
                BorderThickness="0,0,0,5">
                <Grid Margin="20">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        FontSize="26"
                        FontWeight="Bold"
                        Text="理髮區" />

                    <StackPanel
                        Margin="120,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Ellipse
                            x:Name="BarberShape"
                            Width="70"
                            Height="70"
                            Margin="0,0,15,0"
                            Fill="White"
                            Stroke="Black"
                            StrokeThickness="5" />
                        <Ellipse
                            x:Name="ChairShape"
                            Width="70"
                            Height="70"
                            Fill="Black"
                            Stroke="Black"
                            StrokeThickness="5" />
                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <Border
                            Height="45"
                            Margin="0,0,20,0"
                            Padding="15,5"
                            VerticalAlignment="Center"
                            BorderBrush="Black"
                            BorderThickness="4"
                            CornerRadius="10">
                            <TextBlock
                                x:Name="TopWaitCountText"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Text="等候人數" />
                        </Border>

                        <Grid Width="70" Height="70">
                            <Ellipse
                                Fill="White"
                                Stroke="Black"
                                StrokeThickness="5" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Text="clock" />
                        </Grid>
                    </StackPanel>

                    <Border
                        Margin="0,0,0,10"
                        Padding="20,10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        BorderBrush="Black"
                        BorderThickness="4">
                        <TextBlock
                            x:Name="BarberStatusText"
                            FontSize="18"
                            FontWeight="Bold"
                            Text="理髮中..." />
                    </Border>
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                BorderBrush="Black"
                BorderThickness="0,0,0,5">
                <Grid Margin="20">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="26"
                        FontWeight="Bold"
                        Text="等候區" />

                    <StackPanel
                        x:Name="WaitingChairsPanel"
                        Margin="80,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Ellipse
                            Width="55"
                            Height="55"
                            Margin="8"
                            Fill="White"
                            Stroke="Black"
                            StrokeThickness="5" />
                        <Ellipse
                            Width="55"
                            Height="55"
                            Margin="8"
                            Fill="White"
                            Stroke="Black"
                            StrokeThickness="5" />
                        <Ellipse
                            Width="55"
                            Height="55"
                            Margin="8"
                            Fill="White"
                            Stroke="Black"
                            StrokeThickness="5" />
                        <Ellipse
                            Width="55"
                            Height="55"
                            Margin="8"
                            Fill="White"
                            Stroke="Black"
                            StrokeThickness="5" />
                        <Ellipse
                            Width="55"
                            Height="55"
                            Margin="8"
                            Fill="White"
                            Stroke="Black"
                            StrokeThickness="5" />
                        <Ellipse
                            Width="55"
                            Height="55"
                            Margin="8"
                            Fill="White"
                            Stroke="Black"
                            StrokeThickness="5" />
                    </StackPanel>

                    <Button
                        x:Name="ShopStatusButton"
                        Width="120"
                        Height="45"
                        Margin="0,0,0,-5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="White"
                        BorderBrush="Black"
                        BorderThickness="4"
                        Content="OPEN?Close?"
                        FontSize="14"
                        FontWeight="Bold" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="20">
                <TextBlock
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontSize="26"
                    FontWeight="Bold"
                    Text="店外" />

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,5"
                        HorizontalAlignment="Center"
                        FontWeight="Bold"
                        Text="按鈕" />
                    <Button
                        x:Name="ForceCustomerButton"
                        Width="180"
                        Height="60"
                        Background="Transparent"
                        BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    Background="White"
                                    BorderBrush="Black"
                                    BorderThickness="5"
                                    CornerRadius="30">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="22"
                                        FontWeight="Bold"
                                        Text="強制來客" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Column="1" Margin="30">
            <TextBlock
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                FontSize="26"
                FontWeight="Bold"
                Text="統計區" />

            <StackPanel
                Margin="10,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center">
                <TextBlock
                    x:Name="StatWaitingText"
                    Margin="0,15"
                    FontSize="20"
                    FontWeight="Bold"
                    Text="等候人數：" />
                <TextBlock
                    x:Name="StatFinishedText"
                    Margin="0,15"
                    FontSize="20"
                    FontWeight="Bold"
                    Text="剪完人數：" />
                <TextBlock
                    x:Name="StatTurnedAwayText"
                    Margin="0,15"
                    FontSize="20"
                    FontWeight="Bold"
                    Text="氣走人數：" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>