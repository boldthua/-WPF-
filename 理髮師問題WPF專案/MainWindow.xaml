<Window
    x:Class="理髮師問題WPF專案.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Sleeping Barber Simulator"
    Width="900"
    Height="600">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"></ColumnDefinition>
            <ColumnDefinition Width="1*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="4*"></RowDefinition>
            <RowDefinition Height="3*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="15">
            <Label Content="理髮區" Width="75" HorizontalAlignment="Left" HorizontalContentAlignment="Center"  FontSize="18" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,35,0,0">
                <Border BorderBrush="Blue" BorderThickness="3" CornerRadius="10" Width="80" Height="80" Margin="5">
                    <Grid>
                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="25">空</Label>
                    </Grid>
                </Border>
                <Border BorderBrush="Red" BorderThickness="3" CornerRadius="10" Width="85" Height="80" Margin="5">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="理髮師狀態" FontSize="14" Width="80" TextAlignment="Center"/>
                            <Separator Background="Red" Height="2" Margin="0"/>
                            <TextBlock Text="睡覺中" FontSize="16" Width="80" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Margin="15">
            <Label Content="等候區" Width="75" HorizontalAlignment="Left" HorizontalContentAlignment="Center"  FontSize="18" FontWeight="Bold" />
            <Border HorizontalAlignment="Right" BorderBrush="Red" BorderThickness="2" Margin="0,0,20,0">
                <StackPanel>
                    <TextBlock Text="顧客編號" FontSize="16" Width="80" TextAlignment="Center"/>
                    <Separator Background="Red" Height="2" Margin="0"/>
                    <TextBlock Text="0" FontSize="16" Width="80" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="30,0,0,0">
                <Border BorderBrush="DarkBlue" BorderThickness="2" CornerRadius="10" Width="60" Height="60" Margin="5">
                    <Grid>
                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="25">空</Label>
                    </Grid>
                </Border>
                <Border BorderBrush="DarkBlue" BorderThickness="2" CornerRadius="10" Width="60" Height="60" Margin="5">
                    <Grid>
                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="25">空</Label>
                    </Grid>
                </Border>
                <Border BorderBrush="DarkBlue" BorderThickness="2" CornerRadius="10" Width="60" Height="60" Margin="5">
                    <Grid>
                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="25">空</Label>
                    </Grid>
                </Border>
                <Border BorderBrush="DarkBlue" BorderThickness="2" CornerRadius="10" Width="60" Height="60" Margin="5">
                    <Grid>
                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="25">空</Label>
                    </Grid>
                </Border>
                <Border BorderBrush="DarkBlue" BorderThickness="2" CornerRadius="10" Width="60" Height="60" Margin="5">
                    <Grid>
                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="25">空</Label>
                    </Grid>
                </Border>
                <Border BorderBrush="DarkBlue" BorderThickness="2" CornerRadius="10" Width="60" Height="60" Margin="5">
                    <Grid>
                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="25">空</Label>
                    </Grid>
                </Border>
            </StackPanel>
            
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="0" Margin="15">
            <Label Content="街道" Width="75" HorizontalAlignment="Left" HorizontalContentAlignment="Center"  FontSize="18" FontWeight="Bold" />
            <Button HorizontalAlignment="Center" VerticalAlignment="Bottom" Content="增加客人" FontSize="20" />
        </StackPanel>

        <ScrollViewer Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" 
                  VerticalScrollBarVisibility="Auto">
            <StackPanel >
                <ItemsControl x:Name="MessageList" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>